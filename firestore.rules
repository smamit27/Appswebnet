rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Allowed family emails
    function isAuthorized() {
      return request.auth != null
        && !request.auth.token.firebase.sign_in_provider.matches('anonymous')
        && request.auth.token.email in [
          'smamit27@gmail.com',
          'sweta@gmail.com',
          'swetank.suman@gmail.com',
          'amishi@gmail.com',
          'amit@gmail.com'
        ];
    }

    // Sweta's monthly finance records
    match /financeMonthly_sweta/{docId} {
      allow read: if request.auth != null;
      allow write: if isAuthorized();
    }

    // Amit's monthly finance records
    match /financeMonthly_amit/{docId} {
      allow read: if request.auth != null;
      allow write: if isAuthorized();
    }

    // Family monthly finance records
    match /financeMonthly_family/{docId} {
      allow read: if request.auth != null;
      allow write: if isAuthorized();
    }

    // Gym activity (Amit, Sweta, Amishi)
    match /activities/{person}/gym/{docId} {
      allow read: if request.auth != null;
      allow write, delete: if isAuthorized();
    }

    // Amishi – Daily activity
    match /activities/amishi/daily/{docId} {
      allow read: if request.auth != null;
      allow write: if isAuthorized();
    }

    // Amishi – Fees (Dynamic years: fees, fees_2025_26, fees_2027_28, etc)
    match /activities/amishi/{collectionId}/{docId} {
      allow read: if request.auth != null && collectionId.matches('^fees.*');
      allow write: if isAuthorized() && collectionId.matches('^fees.*');
    }

    // Family events calendar
    match /family/events/{docId} {
      allow read: if request.auth != null;
      allow write, delete: if isAuthorized();
    }

    // Root familyEvents calendar
    match /familyEvents/{docId} {
      allow read: if request.auth != null;
      allow write, delete: if isAuthorized();
    }

    // Purchases tracker records
    match /purchases/{docId} {
      allow read: if request.auth != null;
      allow write, delete: if isAuthorized();
    }

    // Lendings tracker records
    match /lendings/{docId} {
      allow read: if request.auth != null;
      allow write, delete: if isAuthorized();
    }

    // Future purchases wishlist
    match /future_purchases/{docId} {
      allow read: if request.auth != null;
      allow write, delete: if isAuthorized();
    }

    // Portfolio tracker collections
    match /portfolio/{docId} {
      allow read: if request.auth != null;
      allow write, delete: if isAuthorized();
    }
    match /holdings/{docId} {
      allow read: if request.auth != null;
      allow write, delete: if isAuthorized();
    }
    match /transactions/{docId} {
      allow read: if request.auth != null;
      allow write, delete: if isAuthorized();
    }
    match /mutualFunds/{docId} {
      allow read: if request.auth != null;
      allow write, delete: if isAuthorized();
    }
    match /stocks/{docId} {
      allow read: if request.auth != null;
      allow write, delete: if isAuthorized();
    }
    match /portfolioSummary/{docId} {
      allow read: if request.auth != null;
      allow write, delete: if isAuthorized();
    }
    match /watchlist/{docId} {
      allow read: if request.auth != null;
      allow write, delete: if isAuthorized();
    }
    match /settings/{docId} {
      allow read: if request.auth != null;
      allow write, delete: if isAuthorized();
    }
    match /monthlySnapshots/{docId} {
      allow read: if request.auth != null;
      allow write, delete: if isAuthorized();
    }
    match /corporateActions/{docId} {
      allow read: if request.auth != null;
      allow write, delete: if isAuthorized();
    }
    match /dividends/{docId} {
      allow read: if request.auth != null;
      allow write, delete: if isAuthorized();
    }


    // Family member profiles
    match /family/members/{docId} {
      allow read: if request.auth != null;
      allow write: if isAuthorized();
    }
  }
}
