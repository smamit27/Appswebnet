rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Allowed family emails
    function isAuthorized() {
      return request.auth != null
        && !request.auth.token.firebase.sign_in_provider.matches('anonymous')
        && request.auth.token.email in [
          'smamit27@gmail.com',
          'sweta@gmail.com',
          'amishi@gmail.com',
          'amit@gmail.com'
        ];
    }

    // Sweta's monthly finance records
    match /financeMonthly_sweta/{docId} {
      allow read: if request.auth != null;
      allow write: if isAuthorized();
    }

    // Amit's monthly finance records
    match /financeMonthly_amit/{docId} {
      allow read: if request.auth != null;
      allow write: if isAuthorized();
    }

    // Amishi – Gym activity
    match /activities/amishi/gym/{docId} {
      allow read: if request.auth != null;
      allow write, delete: if isAuthorized();
    }

    // Amishi – Daily activity
    match /activities/amishi/daily/{docId} {
      allow read: if request.auth != null;
      allow write: if isAuthorized();
    }

    // Family events calendar
    match /family/events/{docId} {
      allow read: if request.auth != null;
      allow write, delete: if isAuthorized();
    }

    // Family member profiles
    match /family/members/{docId} {
      allow read: if request.auth != null;
      allow write: if isAuthorized();
    }
  }
}
